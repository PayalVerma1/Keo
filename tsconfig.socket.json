{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "target": "ES2020"
  },
  "include": [
    "server.ts",
    "src/lib/config/redis.ts",
    "src/lib/modules/websocket/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
