generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  service       Service[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Service {
  id          String       @id @default(uuid())
  name        String
  description String?
  ownerID     String
  owner       user         @relation(fields: [ownerID], references: [id])
  insights    Insight[]
  metrics     Metrics[]
  logs        Logs[]
  deployment  Deployment[]
  createdAt   DateTime     @default(now())
}

model Metrics {
  id         String   @id @default(uuid())
  cpu        Float
  memory     Float
  throughput Float
  latency    Float
  errors     Float
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id])
  createdAt  DateTime @default(now())
}

model Logs {
  id        String   @id @default(uuid())
  level     String
  message   String
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])
  createdAt DateTime @default(now())
}

model Deployment {
  id        String   @id @default(uuid())
  version   String
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])
  createdAt DateTime @default(now())
}

model Insight {
  id             String   @id @default(uuid())
  severity       String
  rootCause      String
  recommendation String
  metricContext  Json?
  logContext     Json?
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id])
  createdAt      DateTime @default(now())

  @@index([serviceId, createdAt])
}