{
  "name": "keo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:socket": "ts-node --project tsconfig.json server.ts",
    "dev:workers": "ts-node --project tsconfig.json src/lib/workers/index.ts",
    "build": "next build",
    "build:socket": "tsc --project tsconfig.socket.json",
    "build:workers": "tsc --project tsconfig.workers.json && cp -R src/lib/generated dist/src/lib/generated",
    "start": "next start -p 3000",
    "start:socket": "NODE_ENV=production node dist/server.js",
    "start:workers": "NODE_ENV=production node dist/src/lib/workers/index.js",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@next/env": "^16.2.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.2"
  }
}
